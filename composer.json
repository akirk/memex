    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "akirk/wp-app": "^1.2",
        "erusev/parsedown": "^1.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit"
    },
    "autoload": {
        "psr-4": {
            "Memex\\": "src/"
        }
    },
    "authors": [
